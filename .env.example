# Google Workspace / Gmail API
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8102/oauth2callback

# Gmail target inbox
GMAIL_USER_EMAIL=your_email@gmail.com

# YPS App Config
YPS_SCAN_LABEL=INBOX
YPS_SCAN_LIMIT=10
YPS_DRAFT_FOLDER=DRAFT
